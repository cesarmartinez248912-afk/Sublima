# ============================================
# SublimArt Premium — Variables de Entorno
# ============================================
# Copia este archivo como .env.local y rellena los valores reales.
# NUNCA subas .env.local a GitHub.

# ─── Opción A: Resend (RECOMENDADO para Vercel) ─────────────────────────────
# Crea tu cuenta gratuita en https://resend.com
# Luego ve a API Keys y genera una clave
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Opción B: Nodemailer via Gmail / SMTP ───────────────────────────────────
# Si prefieres usar Gmail, activa "Contraseñas de aplicación" en tu cuenta Google
# https://myaccount.google.com/security > Verificación en 2 pasos > Contraseñas de app
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=xxxx xxxx xxxx xxxx

# ─── Correo destino de cotizaciones ─────────────────────────────────────────
# El correo donde recibirás las solicitudes de los clientes
CONTACT_EMAIL=ventas@sublimartpremium.com

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Número de WhatsApp con código de país, sin espacios ni símbolos
# Ejemplo México: 5215512345678 | Ejemplo Colombia: 573001234567
NEXT_PUBLIC_WHATSAPP_NUMBER=5215512345678

# ─── Email del remitente (solo Resend) ───────────────────────────────────────
# Debe ser un dominio verificado en Resend, o usa onboarding@resend.dev para pruebas
RESEND_FROM_EMAIL=cotizaciones@sublimartpremium.com

# ─── Proveedor de email a usar ───────────────────────────────────────────────
# Valores válidos: "resend" | "nodemailer"
EMAIL_PROVIDER=resend
